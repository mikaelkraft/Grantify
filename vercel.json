{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "crons": [
    {
      "path": "/api/cron/daily-blog",
      "schedule": "0 7 * * *"
    }
  ],
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/index?path=:path*" },
    { "source": "/share/blog/:id", "destination": "/api/index?path=share&type=blog&id=:id" },
    {
      "source": "/((?!api|ads\\.txt|sw\\.js|favicon\\.ico|favicon\\.svg|favicon-32\\.png|apple-touch-icon\\.png|logo\\.svg|og-default\\.svg).*)",
      "destination": "/"
    }
  ]
}
