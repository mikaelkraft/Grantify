# Copy to .env for local development
# Never commit your real .env (secrets).

# --- Database ---
# Used by the API/server and scripts.
DATABASE_URL=postgres://USER:PASSWORD@HOST:5432/DBNAME

# --- Local dev ---
# The Vite frontend uses this to call your API server when running locally.
# In production (Vercel) leave VITE_API_URL unset.
VITE_API_URL=http://localhost:3001

# API server port for `npm run server` (optional)
PORT=3001

# --- Offsite blog image uploads (Drive-only) ---
OFFSITE_UPLOADS_ENABLED=true
OFFSITE_UPLOADS_PROVIDER=gdrive

# Google OAuth (Drive)
GDRIVE_CLIENT_ID=
GDRIVE_CLIENT_SECRET=

# Optional override.
# IMPORTANT: must exactly match an Authorized redirect URI in Google Cloud.
# For local dev, you probably want:
#   http://localhost:3001/api/uploads/gdrive/callback
# For production, you probably want:
#   https://YOUR_DOMAIN/api/uploads/gdrive/callback
GDRIVE_REDIRECT_URI=

# --- Optional: seed users (only for local/dev seeding flows) ---
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_PASSWORD=Admin123
SEED_STAFF_USERNAME=staff
SEED_STAFF_PASSWORD=staff123

# --- Optional: Autoblog / AI ---
AUTOBLOG_ENABLED=false
# Vercel Cron Jobs: if you set CRON_SECRET in Vercel, Vercel will call the cron URL with
# `Authorization: Bearer <CRON_SECRET>` automatically.
CRON_SECRET=

# Optional manual trigger secret for local/one-off requests (also supported in code).
BLOG_CRON_SECRET=
GROQ_API_KEY=
UNSPLASH_ACCESS_KEY=
